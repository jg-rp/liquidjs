{
  "compilerOptions": {
    "target": "es6",
    "module":"CommonJS",
    "lib": ["es2019", "dom"],
    "sourceMap": true,
    "outDir": "dist",
    "declaration": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "strict": true,
    "suppressImplicitAnyIndexErrors": true,
    "types": ["jest", "node"],
  },
  "all": true,
  "exclude": [ "node_modules", "dist", "demo", "test" ],
  
}
